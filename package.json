{
  "name": "filecc",
  "version": "1.0.1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "asar": true,
    "asarUnpack": [
      "**/ffmpeg-static/**",
      "**/sharp/**"
    ],
    "appId": "com.bloby.filecc",
    "productName": "FileCC",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "runAfterFinish": false,
      "allowElevation": true,
      "perMachine": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "converters/**",
      "node_modules/**",
      "assets/**"
    ]
  }
}